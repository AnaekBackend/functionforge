[
  {
    "type": "function",
    "function": {
      "name": "apply_leave",
      "description": "Request time off or leave.",
      "parameters": {
        "type": "object",
        "properties": {
          "leave_type": {
            "type": "string",
            "enum": [
              "vacation",
              "sick",
              "pto",
              "wfh",
              "remote",
              "personal",
              "unpaid"
            ],
            "description": "Type of leave"
          },
          "start_date": {
            "type": "string",
            "description": "When leave starts (today, tomorrow, date, etc.)"
          },
          "end_date": {
            "type": "string",
            "description": "When leave ends (optional for single day)"
          },
          "duration": {
            "type": "string",
            "description": "Duration if not using dates"
          }
        },
        "required": [
          "leave_type",
          "start_date"
        ],
        "additionalProperties": false
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "clock_in",
      "description": "Clock in to start work.",
      "parameters": {
        "type": "object",
        "properties": {
          "time": {
            "type": "string",
            "description": "Specific time to clock in (optional, defaults to now)"
          },
          "project": {
            "type": "string",
            "description": "Project name (optional)"
          },
          "client": {
            "type": "string",
            "description": "Client name (optional)"
          }
        },
        "required": [],
        "additionalProperties": false
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "clock_out",
      "description": "Clock out to end work.",
      "parameters": {
        "type": "object",
        "properties": {
          "time": {
            "type": "string",
            "description": "Specific time to clock out (optional, defaults to now)"
          }
        },
        "required": [],
        "additionalProperties": false
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "get_summary",
      "description": "Get absence/availability summary.",
      "parameters": {
        "type": "object",
        "properties": {
          "scope": {
            "type": "string",
            "enum": [
              "self",
              "team",
              "specific_person"
            ],
            "description": "Who to get summary for"
          },
          "person": {
            "type": "string",
            "description": "Person's name if scope is specific_person"
          },
          "date": {
            "type": "string",
            "description": "Date for summary (today, tomorrow, specific date)"
          }
        },
        "required": [
          "scope"
        ],
        "additionalProperties": false
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "get_timesheet",
      "description": "Get timesheet or worked hours.",
      "parameters": {
        "type": "object",
        "properties": {
          "scope": {
            "type": "string",
            "enum": [
              "self",
              "team"
            ],
            "description": "Whose timesheet"
          },
          "period": {
            "type": "string",
            "enum": [
              "today",
              "this_week",
              "last_week",
              "this_month",
              "custom"
            ],
            "description": "Time period"
          },
          "start_date": {
            "type": "string",
            "description": "Start date if period is custom"
          },
          "end_date": {
            "type": "string",
            "description": "End date if period is custom"
          }
        },
        "required": [
          "scope",
          "period"
        ],
        "additionalProperties": false
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "change_manager",
      "description": "Update manager information.",
      "parameters": {
        "type": "object",
        "properties": {
          "manager_name": {
            "type": "string",
            "description": "New manager's name"
          }
        },
        "required": [
          "manager_name"
        ],
        "additionalProperties": false
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "take_break",
      "description": "Go on break (lunch, coffee, etc.).",
      "parameters": {
        "type": "object",
        "properties": {
          "break_type": {
            "type": "string",
            "enum": [
              "lunch",
              "coffee",
              "short",
              "generic"
            ],
            "description": "Type of break"
          },
          "duration_minutes": {
            "type": "integer",
            "minimum": 5,
            "maximum": 120,
            "description": "Expected duration in minutes"
          }
        },
        "required": [
          "break_type"
        ],
        "additionalProperties": false
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "get_help",
      "description": "Request help or information.",
      "parameters": {
        "type": "object",
        "properties": {
          "topic": {
            "type": "string",
            "enum": [
              "general",
              "leave_application",
              "time_tracking",
              "commands",
              "features"
            ],
            "description": "Help topic"
          }
        },
        "required": [
          "topic"
        ],
        "additionalProperties": false
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "ask_clarify",
      "description": "Ask for clarification when request is ambiguous/invalid.",
      "parameters": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string",
            "enum": [
              "missing_dates",
              "ambiguous_leave_type",
              "missing_time",
              "unclear_request",
              "out_of_scope"
            ],
            "description": "Reason for clarification"
          }
        },
        "required": [
          "reason"
        ],
        "additionalProperties": false
      }
    }
  }
]